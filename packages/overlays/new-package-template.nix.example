# nixpkgs by-name compatible format.
# Copy this file as <package-name>.nix and fill in the details.
# The file name (without .nix) becomes the attribute name in nixpkgs overlay.
{
  lib,
  stdenv,
  fetchFromGitHub,
  pkg-config,
}:
stdenv.mkDerivation (finalAttrs: {
  pname = "your-package";
  version = "0.1.0";

  # Replace with your real source.
  src = fetchFromGitHub {
    owner = "your-github-user-or-org";
    repo = "your-repo";
    rev = "v${finalAttrs.version}";
    hash = "sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=";
  };

  nativeBuildInputs = [
    pkg-config
  ];

  # Add runtime/build deps only when needed.
  buildInputs = [
  ];

  # Keep default phases if upstream uses a standard build system.
  # Uncomment and customize only if you need manual steps.
  # buildPhase = ''
  #   runHook preBuild
  #   make
  #   runHook postBuild
  # '';

  # installPhase = ''
  #   runHook preInstall
  #   install -Dm755 ./your-binary "$out/bin/${finalAttrs.pname}"
  #   runHook postInstall
  # '';

  meta = {
    description = "Short description of the package";
    homepage = "https://github.com/your-github-user-or-org/your-repo";
    license = lib.licenses.mit;
    mainProgram = "your-package";
    platforms = lib.platforms.linux;
  };
})
